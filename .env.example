# Cron job protection secret — set to any random string
# Must match the Authorization: Bearer <secret> header sent by Vercel crons
CRON_SECRET=your_random_secret_here

# --- Admin ---
# Comma-separated list of admin user emails
ADMIN_EMAILS=admin@nobrakes.sports
