{
  "crons": [
    {
      "path": "/api/cron/sync-odds",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/sync-kalshi",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/sync-polymarket",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/sync-underdog",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sync-sleeper",
      "schedule": "2-59/5 * * * *"
    },
    {
      "path": "/api/cron/sync-bovada",
      "schedule": "3-59/5 * * * *"
    },
    {
      "path": "/api/cron/sync-pipelines",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sync-props",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/random-arb-alert",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/random-ev-alert",
      "schedule": "*/30 * * * *"
    }
  ],
  "functions": {
    "app/api/cron/sync-odds/route.ts": { "maxDuration": 300 },
    "app/api/cron/sync-kalshi/route.ts": { "maxDuration": 30 },
    "app/api/cron/sync-polymarket/route.ts": { "maxDuration": 60 },
    "app/api/cron/sync-pipelines/route.ts": { "maxDuration": 300 },
    "app/api/pipelines/run/route.ts": { "maxDuration": 300 },
    "app/api/cron/sync-props/route.ts": { "maxDuration": 300 },
    "app/api/cron/random-arb-alert/route.ts": { "maxDuration": 30 },
    "app/api/cron/random-ev-alert/route.ts": { "maxDuration": 30 },
    "app/api/cron/sync-underdog/route.ts": { "maxDuration": 120 },
    "app/api/cron/sync-sleeper/route.ts": { "maxDuration": 90 },
    "app/api/cron/sync-bovada/route.ts": { "maxDuration": 60 },
    "app/api/cron/sync-betonline/route.ts": { "maxDuration": 90 }
  }
}
