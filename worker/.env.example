# Copy this to .env and fill in values.
# On Railway, set these in the service's Variables tab instead.

# ── Supabase ───────────────────────────────────────────────────────────────
# Must use the service role key — worker writes to prop_odds / current_market_odds
SUPABASE_URL=https://qxqxzexfmgqwwbfkfogt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Worker config ──────────────────────────────────────────────────────────
# Comma-separated list of book slugs to enable. Omit to run everything.
# Example: ENABLED_BOOKS=pointsbet_on,bet99,caesars
ENABLED_BOOKS=

# Default polling interval (seconds). Individual adapters can override.
DEFAULT_POLL_INTERVAL=60

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Port for the /health endpoint. Railway sets this automatically.
PORT=8080
